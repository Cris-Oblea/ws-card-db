# --- Regenerable / heavy data (rebuilt by the pipeline) ---
# Raw harvest (~59 MB) and features (~73 MB): re-derivable. Not versioned.
pipeline/ingest/cardlist_full.json
pipeline/ingest/cardlist_full.jsonl
pipeline/ingest/cardlist_full.state.json
pipeline/ingest/features_by_card.csv

# --- Cache and transient artifacts ---
__pycache__/
*.pyc
pipeline/_tr/
pipeline/_archive/
to_translate.json

# --- App build: both the uncompressed and gzipped DB are build output now.
# ws.sqlite.gz used to be committed so a fresh clone could browse without building,
# but each rebuild added a ~10-13MB blob that git can't delta-compress (gzip output
# is high-entropy) -- 79 historical versions had bloated .git by ~820MB. CI now
# builds it fresh on every deploy (see .github/workflows/deploy-pages.yml), so it
# no longer needs to be tracked. Run `python pipeline/build_db.py` locally to get it.
site/ws.sqlite
site/ws.sqlite.gz

# --- Excel cost sheets: generated on demand, not versioned (the deliverable is the site) ---
deliverables/
pipeline/*.xlsx

# --- Read-only cost analysis outputs (regenerated by cost_standardize.py) ---
pipeline/analysis/

# --- OS junk ---
Thumbs.db
.DS_Store
desktop.ini

# translation workflow temp
pipeline/_tr_batches/
pipeline/_tr_manifest.json
pipeline/_tr2/
